# ═══════════════════════════════════════════════════════════════
# WriteTextAmp Workspace — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Este arquivo é gerado pela GUI de configuração (configure-gui.py)
# ou manualmente copiando .env.template para .env
# ═══════════════════════════════════════════════════════════════

# ─── Documentos (Sempre Habilitados) ───
# Estes MCPs estão sempre habilitados e não requerem configuração
# document-generator: Word + PDF profissional
# pdf-toolkit: PDF avançado (merge, split, encrypt, QR)

# ─── Geração de Imagem AI ───

# FLUX (Black Forest Labs) — Imagens AI de alta qualidade
# Free tier: https://bfl.ai (requer conta, usa OAuth)
FLUX_ENABLED=false

# Pictify — Templates HTML para imagens, GIFs e PDFs
# Free tier: https://pictify.io
# API Key: https://pictify.io/dashboard/api-tokens
PICTIFY_ENABLED=false
PICTIFY_API_KEY=

# Open Design — Prototipagem visual local (Electron)
# Open source: https://github.com/nexu-io/open-design
# Instalação automática via setup.ps1
OPEN_DESIGN_ENABLED=false
OPEN_DESIGN_PORT=3333

# ─── Edição de Imagem ───

# ChangeImageTo — 16 ferramentas de edição
# Free tier: https://changeimageto.com
CHANGEIMAGETO_ENABLED=false

# Chompute BG Remover — Remoção de fundo
# Free tier: https://chompute.com
CHOMPUTE_ENABLED=false

# Nano Banana — Edição com Google Gemini
# Free tier: https://nanobanana.com
NANO_BANANA_ENABLED=false

# ─── Redes Sociais ───

# LinkedIn — Postar e gerenciar conteúdo
# Requer OAuth (autenticação via navegador)
LINKEDIN_ENABLED=false

# Twitter/X — Threads e posts
# Requer API keys: https://developer.twitter.com
TWITTER_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Instagram — Posts e stories
# Requer OAuth (autenticação via navegador)
INSTAGRAM_ENABLED=false

# Facebook — Posts em páginas e grupos
# Requer OAuth (autenticação via navegador)
FACEBOOK_ENABLED=false

# ─── Produtividade e Organização ───

# Notion — Documentação e gestão de projetos
# API Key: https://www.notion.so/my-integrations
NOTION_ENABLED=false
NOTION_API_KEY=

# Google Drive — Armazenamento e compartilhamento
# Requer OAuth (autenticação via navegador)
GOOGLE_DRIVE_ENABLED=false

# Slack — Comunicação e aprovações
# Requer OAuth (autenticação via navegador)
SLACK_ENABLED=false

# ─── Pesquisa e SEO ───

# Brave Search — Pesquisa web
# Free tier: https://brave.com/search/api/
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=

# SEOcrawl — Análise SEO e performance
# Requer API key: https://seocrawl.com
SEOCRAWL_ENABLED=false
SEOCRAWL_API_KEY=

# OpenSEO — Dados de keywords e análise
# Free tier: https://openseo.com
OPENSEO_ENABLED=false

# ─── Configurações Adicionais ───

# Idioma padrão do workspace
DEFAULT_LANGUAGE=pt-BR

# Formato de data
DATE_FORMAT=YYYY-MM-DD

# Timezone
TIMEZONE=America/Sao_Paulo
