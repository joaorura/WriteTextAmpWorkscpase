{
  "mcpServers": {
    "docling": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-docling"],
      "description": "Processamento de documentos (PDF, DOCX, imagens)"
    },
    "document-generator": {
      "command": "npx",
      "args": ["--yes", "document-generator-mcp@latest"],
      "description": "Geração de documentos Word e PDF profissionais"
    },
    "pdf-toolkit": {
      "command": "npx",
      "args": ["-y", "@aryanbv/pdf-toolkit-mcp"],
      "description": "PDF avançado: merge, split, encrypt, QR codes"
    },
    "flux": {
      "command": "npx",
      "args": ["-y", "@bfl/mcp-server-flux"],
      "env": {
        "FLUX_API_KEY": "${FLUX_API_KEY}"
      },
      "description": "FLUX - Geração de imagens AI (Black Forest Labs)"
    },
    "pictify": {
      "command": "npx",
      "args": ["-y", "@pictify/mcp-server"],
      "env": {
        "PICTIFY_API_KEY": "${PICTIFY_API_KEY}"
      },
      "description": "Pictify - Templates HTML para imagens"
    },
    "changeimageto": {
      "command": "npx",
      "args": ["-y", "@changeimageto/mcp-server"],
      "description": "ChangeImageTo - Edição de imagem (16 ferramentas)"
    },
    "chompute": {
      "command": "npx",
      "args": ["-y", "@chompute/mcp-server"],
      "description": "Chompute - Remoção de fundo"
    },
    "nano-banana": {
      "command": "npx",
      "args": ["-y", "@nanobanana/mcp-server"],
      "env": {
        "NANO_BANANA_API_KEY": "${NANO_BANANA_API_KEY}"
      },
      "description": "Nano Banana - Edição com Google Gemini"
    }
  }
}
