{
  "mcp": {
    "docling": {
      "command": "npx",
      "args": ["-y", "@antigravity/mcp-server-docling"],
      "description": "Processamento de documentos"
    },
    "document-generator": {
      "command": "npx",
      "args": ["--yes", "document-generator-mcp@latest"],
      "description": "Word + PDF profissional"
    },
    "pdf-toolkit": {
      "command": "npx",
      "args": ["-y", "@aryanbv/pdf-toolkit-mcp"],
      "description": "PDF avançado"
    },
    "flux": {
      "command": "npx",
      "args": ["-y", "@bfl/mcp-server-flux"],
      "env": { "FLUX_API_KEY": "${FLUX_API_KEY}" },
      "description": "FLUX - Imagens AI"
    },
    "pictify": {
      "command": "npx",
      "args": ["-y", "@pictify/mcp-server"],
      "env": { "PICTIFY_API_KEY": "${PICTIFY_API_KEY}" },
      "description": "Pictify - Templates HTML"
    },
    "changeimageto": {
      "command": "npx",
      "args": ["-y", "@changeimageto/mcp-server"],
      "description": "ChangeImageTo - Edição"
    },
    "chompute": {
      "command": "npx",
      "args": ["-y", "@chompute/mcp-server"],
      "description": "Chompute - Remoção de fundo"
    },
    "nano-banana": {
      "command": "npx",
      "args": ["-y", "@nanobanana/mcp-server"],
      "env": { "NANO_BANANA_API_KEY": "${NANO_BANANA_API_KEY}" },
      "description": "Nano Banana - Edição Gemini"
    }
  }
}
